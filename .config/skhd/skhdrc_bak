# -----------------------------
# skhd — minimal safe bindings
# -----------------------------

# Focus windows (AeroSpace-style)
alt - h : yabai -m window --focus west
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - l : yabai -m window --focus east

# Move windows
alt + shift - h : yabai -m window --move west
alt + shift - j : yabai -m window --move south
alt + shift - k : yabai -m window --move north
alt + shift - l : yabai -m window --move east


alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6

alt + shift - 1 : yabai -m window --space 1; yabai -m space --focus 1
alt + shift - 2 : yabai -m window --space 2; yabai -m space --focus 2
alt + shift - 3 : yabai -m window --space 3; yabai -m space --focus 3
alt + shift - 4 : yabai -m window --space 4; yabai -m space --focus 4
alt + shift - 5 : yabai -m window --space 5; yabai -m space --focus 5
alt + shift - 6 : yabai -m window --space 6; yabai -m space --focus 6


alt - tab : yabai -m space --focus recent

alt - comma  : yabai -m display --focus prev
alt - period : yabai -m display --focus next

alt + shift - comma  : yabai -m window --display prev; sleep 0.01; yabai -m display --focus prev
alt + shift - period : yabai -m window --display next;sleep 0.01; yabai -m display --focus next


# Toggle fullscreen
alt + ctrl + shift - f : yabai -m window --toggle zoom-fullscreen

# Balance BSP tree
alt - b : yabai -m space --balance
alt + ctrl - h : yabai -m window --resize left:-40:0
alt + ctrl - l : yabai -m window --resize right:40:0
alt + ctrl - j : yabai -m window --resize bottom:0:40
alt + ctrl - k : yabai -m window --resize top:0:-40

alt - space : yabai -m window --toggle float

alt + shift - space : yabai -m window --grid 4:4:1:1:2:2


