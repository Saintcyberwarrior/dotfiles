#!/usr/bin/env sh

# Ensure CONFIG_DIR exists
: "${CONFIG_DIR:=$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"
THEME_FILE="$HOME/.config/themes/current/shellcolors.sh"

# Theme Colors
if [ -r "$THEME_FILE" ]; then
  source "$THEME_FILE"
else
  BACKGROUND=0xbb111111
  CLOCK=0xffffffff
  ACTIVE=0xfffe8019
fi

##### Bar Appearance #####
bar=(
  position=top
  height=32
  margin=10
  y_offset=5
  blur_radius=20
  color=0xbb111111
  corner_radius=10
  border_width=1
  border_color=0x44ffffff
  shadow=on
)
sketchybar --bar "${bar[@]}"

##### Defaults #####
FONT="JetBrainsMonoNL Nerd Font"

default=(
  icon.font="$FONT:Bold:14.0"
  label.font="$FONT:Bold:13.0"
  icon.color=0xffffffff
  label.color=0xffffffff
  icon.padding_left=5
  icon.padding_right=5
  label.padding_left=5
  label.padding_right=5
  background.height=24
  background.corner_radius=5
)
sketchybar --default "${default[@]}"

##### Spaces (Dynamic from Yabai) #####
# Fetch space indices from yabai
SPACES=$(yabai -m query --spaces | jq -r '.[].index')

for i in $SPACES; do
  sketchybar --add space space."$i" left \
             --set space."$i" space="$i" \
                                icon="$i" \
                                label.drawing=off \
                                background.drawing=on \
                                background.color=0x00000000 \
                                script="$PLUGIN_DIR/space.sh" \
                                click_script="yabai -m space --focus $i"
done

sketchybar --add bracket spaces '/space\..*/' \
           --set spaces background.color=$BACKGROUND background.drawing=on

##### Items #####

# Media: Increased padding to center between spaces and front_app
sketchybar --add item media left \
           --set media icon="󰝚" \
                       label.max_chars=25 \
                       scroll_texts=off \
                       update_freq=2 \
                       padding_left=30 \
                       script="$PLUGIN_DIR/media.sh" \
                       icon.font="JetBrainsMonoNL Nerd Font:Bold:14.0" \
                       background.color=$BACKGROUND \
                       background.drawing=on \
           --subscribe media media_change

# Front App (Workspace Name)
sketchybar --add item front_app center \
           --set front_app script="$PLUGIN_DIR/front_app.sh" \
                           icon.font="sketchybar-app-font:Regular:16.0" \
                           background.drawing=off \
           --subscribe front_app front_app_switched

# System Items (Right side)
sketchybar --add item clock right \
           --set clock update_freq=10 \
                       icon="󰥔" \
                       script="$PLUGIN_DIR/clock.sh" \
                       background.color=$BACKGROUND \
                       background.drawing=on

sketchybar --add item volume right \
           --set volume script="$PLUGIN_DIR/volume.sh" \
                       background.color=$BACKGROUND \
                       background.drawing=on \
           --subscribe volume volume_change

sketchybar --add item battery right \
           --set battery update_freq=60 \
                         script="$PLUGIN_DIR/battery.sh" \
                         background.color=$BACKGROUND \
                         background.drawing=on \
           --subscribe battery system_woke power_source_change

sketchybar --update
